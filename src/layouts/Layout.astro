---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Chaos Media — viralowe zasięgi w sporcie i mediach",
  description = "Tworzymy viralowe treści, które generują setki milionów wyświetleń. Łączymy media, sport i internet w jedną potężną machinę zasięgów.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body class="bg-ink text-bone">
    <slot />
  </body>
</html>
