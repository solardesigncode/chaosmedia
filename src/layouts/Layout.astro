---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Chaos Media — viralowe zasięgi w sporcie i mediach",
  description = "Tworzymy viralowe treści, które generują setki milionów wyświetleń. Łączymy media, sport i internet w jedną potężną machinę zasięgów.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body class="bg-ink text-bone">
    <slot />

    <div id="cursor-dot" class="cursor-dot" aria-hidden="true"></div>

    <style is:global>
      @media (hover: hover) and (pointer: fine) {
        html,
        html * {
          cursor: none !important;
        }
      }

      .cursor-dot {
        position: fixed;
        top: 0;
        left: 0;
        width: 12px;
        height: 12px;
        border-radius: 9999px;
        background: var(--color-acid);
        pointer-events: none;
        transform: translate3d(-100px, -100px, 0);
        transition: opacity 0.2s ease, width 0.25s ease, height 0.25s ease;
        will-change: transform;
        z-index: 9999;
        opacity: 0;
        display: none;
      }

      @media (hover: hover) and (pointer: fine) {
        .cursor-dot {
          display: block;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .cursor-dot {
          transition: none;
        }
      }
    </style>

    <script is:inline>
      (function () {
        if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches)
          return;

        const dot = document.getElementById("cursor-dot");
        if (!dot) return;

        let targetX = -100;
        let targetY = -100;
        let currX = -100;
        let currY = -100;
        let visible = false;
        let rafId = 0;
        const reduce = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        const lerp = reduce ? 1 : 0.28;

        const tick = () => {
          currX += (targetX - currX) * lerp;
          currY += (targetY - currY) * lerp;
          dot.style.transform =
            "translate3d(" +
            (currX - 6) +
            "px, " +
            (currY - 6) +
            "px, 0)";
          rafId = requestAnimationFrame(tick);
        };

        document.addEventListener(
          "mousemove",
          (e) => {
            targetX = e.clientX;
            targetY = e.clientY;
            if (!visible) {
              visible = true;
              currX = targetX;
              currY = targetY;
              dot.style.opacity = "1";
            }
          },
          { passive: true }
        );

        document.addEventListener("mouseleave", () => {
          visible = false;
          dot.style.opacity = "0";
        });
        document.addEventListener("mouseenter", () => {
          visible = true;
          dot.style.opacity = "1";
        });

        // Swap cursor colour when hovering an acid-filled button so the dot
        // stays visible: solid black on yellow, default yellow everywhere else.
        const acidSelector = "[data-cursor='invert'], .bg-acid";
        document.addEventListener(
          "mouseover",
          (e) => {
            const el =
              e.target instanceof Element ? e.target.closest(acidSelector) : null;
            if (el) dot.classList.add("on-acid");
          },
          { passive: true }
        );
        document.addEventListener(
          "mouseout",
          (e) => {
            const el =
              e.target instanceof Element ? e.target.closest(acidSelector) : null;
            if (el) dot.classList.remove("on-acid");
          },
          { passive: true }
        );

        rafId = requestAnimationFrame(tick);

        window.addEventListener(
          "pagehide",
          () => cancelAnimationFrame(rafId),
          { once: true }
        );
      })();
    </script>

    <style is:global>
      .cursor-dot.on-acid {
        background: var(--color-ink);
        width: 14px;
        height: 14px;
      }
    </style>
  </body>
</html>
