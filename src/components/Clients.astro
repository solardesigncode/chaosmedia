---
type Client = { name: string; logo?: string };

const clients: Client[] = [
  { name: "eFortuna.pl", logo: "/logos/partners/efortuna.svg" },
  { name: "Superbet", logo: "/logos/partners/superbet.svg" },
  { name: "Monster Energy", logo: "/logos/partners/monster.webp" },
  { name: "Royal Watch", logo: "/logos/partners/royal-watch.png" },
  { name: "GROMDA", logo: "/logos/partners/gromda.webp" },
  { name: "DAZN", logo: "/logos/partners/dazn.png" },
  { name: "Sportowe Fakty WP", logo: "/logos/partners/sportowefakty.svg" },
  { name: "wlepki.com" },
  { name: "octagonshop.pl", logo: "/logos/partners/octagon.png" },
  { name: "skleptmk.pl" },
];
const loop = [...clients, ...clients];
---

<section class="py-20 lg:py-28 border-t border-white/10 bg-smoke">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 mb-12 flex items-center justify-between">
    <div class="text-xs uppercase tracking-[0.32em] text-acid">03 — Zaufali nam</div>
    <div class="text-xs uppercase tracking-[0.18em] text-bone/40">{clients.length} marek · i więcej</div>
  </div>

  <div class="relative">
    <div
      class="ticker-viewport relative overflow-hidden touch-pan-y"
      data-ticker-duration-desktop="14"
      data-ticker-duration-mobile="8"
    >
      <div class="ticker-track flex items-center whitespace-nowrap w-max will-change-transform">
        {loop.map((c, i) => {
          const ghost = i >= clients.length;
          return (
            <div class="flex items-center gap-12 lg:gap-16 pr-12 lg:pr-16 shrink-0">
              {c.logo ? (
                <img
                  src={c.logo}
                  alt={ghost ? "" : `Logo ${c.name}`}
                  aria-hidden={ghost ? "true" : undefined}
                  loading="eager"
                  decoding="sync"
                  fetchpriority="high"
                  class="partner-logo h-10 lg:h-14 w-auto max-w-[180px] lg:max-w-[220px] object-contain"
                />
              ) : (
                <span
                  class="font-display font-bold text-bone/30 hover:text-acid transition-colors text-3xl lg:text-5xl tracking-tight"
                  aria-hidden={ghost ? "true" : undefined}
                >
                  {c.name}
                </span>
              )}
              <span class="text-acid/50 text-2xl lg:text-3xl shrink-0" aria-hidden="true">/</span>
            </div>
          );
        })}
      </div>
    </div>
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 lg:w-40 bg-gradient-to-r from-smoke to-transparent z-10"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 lg:w-40 bg-gradient-to-l from-smoke to-transparent z-10"></div>
  </div>
</section>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const viewports = document.querySelectorAll<HTMLElement>(".ticker-viewport");

  viewports.forEach((viewport) => {
    const track = viewport.querySelector<HTMLElement>(".ticker-track");
    if (!track) return;

    const desktopDuration = parseFloat(viewport.dataset.tickerDurationDesktop ?? "6");
    const mobileDuration = parseFloat(viewport.dataset.tickerDurationMobile ?? "3");

    let offset = 0;
    let dragging = false;
    let dragStartX = 0;
    let offsetAtDragStart = 0;
    let lastTime = performance.now();
    let rafId = 0;

    const apply = () => {
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    if (reduceMotion) {
      apply();
      return;
    }

    const tick = (now: number) => {
      const delta = now - lastTime;
      lastTime = now;

      const halfWidth = track.scrollWidth / 2;
      if (halfWidth > 0) {
        if (!dragging) {
          const isMobile = window.matchMedia("(max-width: 767px)").matches;
          const duration = isMobile ? mobileDuration : desktopDuration;
          const speedPxPerSec = halfWidth / duration;
          offset -= (speedPxPerSec * delta) / 1000;
        }

        // Seamless wrap — keep offset inside (-halfWidth, 0]
        while (offset <= -halfWidth) offset += halfWidth;
        while (offset > 0) offset -= halfWidth;
      }

      apply();
      rafId = requestAnimationFrame(tick);
    };

    const pointerDown = (clientX: number) => {
      dragging = true;
      dragStartX = clientX;
      offsetAtDragStart = offset;
    };
    const pointerMove = (clientX: number) => {
      if (!dragging) return;
      offset = offsetAtDragStart + (clientX - dragStartX);
    };
    const pointerUp = () => {
      dragging = false;
      lastTime = performance.now();
    };

    viewport.addEventListener(
      "touchstart",
      (e) => pointerDown(e.touches[0].clientX),
      { passive: true }
    );
    viewport.addEventListener(
      "touchmove",
      (e) => pointerMove(e.touches[0].clientX),
      { passive: true }
    );
    viewport.addEventListener("touchend", pointerUp, { passive: true });
    viewport.addEventListener("touchcancel", pointerUp, { passive: true });

    // Mouse drag on desktop
    viewport.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse") return;
      pointerDown(e.clientX);
    });
    viewport.addEventListener("pointermove", (e) => {
      if (e.pointerType !== "mouse") return;
      pointerMove(e.clientX);
    });
    viewport.addEventListener("pointerup", (e) => {
      if (e.pointerType !== "mouse") return;
      pointerUp();
    });
    viewport.addEventListener("pointerleave", (e) => {
      if (e.pointerType !== "mouse") return;
      pointerUp();
    });

    rafId = requestAnimationFrame(tick);

    window.addEventListener(
      "pagehide",
      () => cancelAnimationFrame(rafId),
      { once: true }
    );
  });
</script>

<style is:global>
  /* Raster partner logos (png/webp) forced to white silhouettes so they
     match the monochrome landing-page aesthetic. */
  .partner-logo {
    filter: brightness(0) invert(1);
    opacity: 0.55;
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  .partner-logo:hover {
    opacity: 1;
    transform: scale(1.04);
  }
</style>
