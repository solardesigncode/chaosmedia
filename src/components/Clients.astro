---
const clients = [
  "eFortuna.pl",
  "Superbet",
  "Monster Energy",
  "Royal Watch",
  "GROMDA",
  "DAZN",
  "Sportowe Fakty WP",
  "wlepki.com",
  "octagonshop.pl",
  "skleptmk.pl",
];
const loop = [...clients, ...clients];
---

<section class="py-20 lg:py-28 border-t border-white/10 bg-smoke">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 mb-12 flex items-center justify-between">
    <div class="text-xs uppercase tracking-[0.32em] text-bone/50">03 — Zaufali nam</div>
    <div class="text-xs uppercase tracking-[0.18em] text-bone/40">{clients.length} marek · i więcej</div>
  </div>

  <div class="relative overflow-hidden">
    <div class="ticker flex gap-16 whitespace-nowrap will-change-transform">
      {loop.map((c) => (
        <span class="font-display font-bold text-bone/30 hover:text-acid transition-colors text-4xl lg:text-6xl tracking-tight">
          {c} <span class="text-acid/60 mx-6">/</span>
        </span>
      ))}
    </div>
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-smoke to-transparent"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-smoke to-transparent"></div>
  </div>
</section>
