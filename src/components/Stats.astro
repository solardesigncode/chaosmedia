---
const stats = [
  {
    tag: "Społeczność",
    value: 12,
    decimals: 0,
    suffix: "mln+",
    label: "obserwujących w social mediach",
  },
  {
    tag: "Zasięg",
    value: 1.2,
    decimals: 1,
    suffix: "mld+",
    label: "wyświetleń miesięcznie",
  },
  {
    tag: "Zaangażowanie",
    value: 100,
    decimals: 0,
    suffix: "mln+",
    label: "interakcji miesięcznie",
  },
  {
    tag: "Pojedyncza akcja",
    value: 50,
    decimals: 0,
    suffix: "mln",
    label: "zasięgu w 24h — i to nie maks",
  },
];

const initialValue = (s: (typeof stats)[number]) =>
  (0).toFixed(s.decimals).replace(".", ",");
---

<section class="border-y border-white/10 bg-smoke">
  <div class="max-w-[1400px] mx-auto">
    <div class="px-6 lg:px-10 pt-24 lg:pt-36 relative grid lg:grid-cols-12 gap-10 lg:gap-12 items-end">
      <div class="lg:col-span-7 relative z-10 pb-16 lg:pb-28">
        <div class="flex items-center gap-3 text-xs uppercase tracking-[0.32em] text-acid mb-10 lg:mb-14">
          <span class="inline-block w-8 h-px bg-acid"></span>
          Chaos Media w liczbach
        </div>

        <h2 class="font-display font-semibold text-bone text-[clamp(1.75rem,5vw,5rem)] leading-[1] tracking-[-0.025em] max-w-[22ch] text-balance">
          Łączymy <span class="text-acid">media</span>, <span class="text-acid">sport</span> <span class="whitespace-nowrap">i&nbsp;<span class="text-acid">internet</span></span> w jedną potężną machinę zasięgów.
        </h2>

        <p class="mt-10 lg:mt-14 text-base lg:text-xl text-bone/65 max-w-2xl leading-relaxed">
          Własne portale, własne studio, własne formaty — i dystrybucja, której zazdroszczą najwięksi.
        </p>
      </div>

      <div class="hidden lg:block lg:col-span-5 self-end relative">
        <div class="stats-laptop-orbit" aria-hidden="true"></div>
        <div
          class="stats-badges absolute inset-x-0 top-[-6rem] xl:top-[-8rem] flex items-center justify-center gap-2.5 lg:gap-3.5 z-[5] pointer-events-none"
          aria-hidden="true"
        >
          <div class="badge" style="--i:0"><span>media</span></div>
          <span class="plus" style="--i:1">+</span>
          <div class="badge" style="--i:2"><span>sport</span></div>
          <span class="plus" style="--i:3">+</span>
          <div class="badge" style="--i:4"><span>internet</span></div>
        </div>
        <img
          src="/images/laptop.png"
          alt="Laptop z otwartym portalem Fansportu.pl"
          loading="lazy"
          decoding="async"
          class="relative z-10 block w-full h-auto ml-auto select-none pointer-events-none lg:max-w-[600px]"
          width="880"
          height="602"
        />
      </div>
    </div>

    <style is:global>
      .stats-laptop-orbit {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }
      .stats-laptop-orbit::before {
        content: "";
        position: absolute;
        /* Ball locked slightly above centre of laptop wrap. */
        width: 70%;
        height: 70%;
        top: 5%;
        left: 15%;
        border-radius: 9999px;
        background:
          radial-gradient(
            circle,
            rgba(230, 255, 0, 0.55) 0%,
            rgba(230, 255, 0, 0.22) 40%,
            rgba(230, 255, 0, 0.08) 65%,
            transparent 78%
          );
        filter: blur(60px);
        will-change: transform, opacity;
        animation: stats-laptop-pulse 7s cubic-bezier(0.45, 0, 0.55, 1) infinite;
      }
      @keyframes stats-laptop-pulse {
        0%,
        100% {
          transform: scale(0.9);
          opacity: 0.55;
        }
        50% {
          transform: scale(1.15);
          opacity: 1;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .stats-laptop-orbit::before {
          animation: none;
        }
      }

      .stats-badges .badge,
      .stats-badges .plus {
        transform: translateY(200px);
        opacity: 0;
        transition:
          transform 1.1s cubic-bezier(0.16, 1, 0.3, 1),
          opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: calc(var(--i, 0) * 0.12s);
      }
      .stats-badges.in-view .badge,
      .stats-badges.in-view .plus {
        transform: translateY(0);
        opacity: 1;
      }

      .stats-badges .badge {
        display: flex;
        align-items: center;
        justify-content: center;
        width: clamp(4rem, 5.5vw, 5.75rem);
        height: clamp(4rem, 5.5vw, 5.75rem);
        border-radius: 9999px;
        background: var(--color-acid);
        color: var(--color-ink);
        font-family: var(--font-display);
        font-weight: 600;
        font-size: clamp(0.75rem, 0.9vw, 1rem);
        text-transform: lowercase;
        box-shadow:
          0 12px 36px -10px rgba(230, 255, 0, 0.38),
          inset 0 0 0 1px rgba(230, 255, 0, 0.45);
      }
      .stats-badges .plus {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: clamp(1rem, 1.3vw, 1.5rem);
        color: var(--color-bone);
        flex-shrink: 0;
      }

      @media (prefers-reduced-motion: reduce) {
        .stats-badges .badge,
        .stats-badges .plus {
          transition: none;
          transform: none;
          opacity: 1;
        }
      }
    </style>

  </div>
  <div class="border-t border-white/10"></div>
  <div class="max-w-[1400px] mx-auto">
    <div class="grid grid-cols-4 divide-x divide-white/10">
      {stats.map((stat) => (
        <div class="p-4 sm:p-6 md:p-8 lg:p-12 group hover:bg-ink transition-colors">
          <div class="text-[9px] sm:text-[10px] md:text-[11px] uppercase tracking-[0.2em] md:tracking-[0.24em] text-acid">
            {stat.tag}
          </div>
          <div
            class="counter mt-4 md:mt-6 flex items-baseline gap-1 sm:gap-1.5 md:gap-2 whitespace-nowrap font-display font-semibold text-bone leading-none tracking-[-0.04em]"
            data-count-to={stat.value}
            data-count-decimals={stat.decimals}
            data-count-suffix={stat.suffix}
          >
            <span class="counter-num text-2xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl tabular-nums">
              {initialValue(stat)}
            </span>
            <span class="counter-unit text-[11px] sm:text-sm md:text-base lg:text-lg xl:text-xl font-sans font-medium text-bone/70 tracking-[0.02em]">
              {stat.suffix}
            </span>
          </div>
          <div class="mt-3 md:mt-4 text-[11px] sm:text-xs md:text-sm text-bone/60 max-w-[20ch]">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll<HTMLElement>(".counter");

  const format = (n: number, decimals: number) =>
    n.toFixed(decimals).replace(".", ",");

  const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

  const animate = (el: HTMLElement) => {
    const numEl = el.querySelector<HTMLElement>(".counter-num");
    if (!numEl) return;
    const to = parseFloat(el.dataset.countTo ?? "0");
    const decimals = parseInt(el.dataset.countDecimals ?? "0", 10);
    const duration = 1800;
    const start = performance.now();

    const step = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const current = to * easeOutCubic(t);
      numEl.textContent = format(current, decimals);
      if (t < 1) requestAnimationFrame(step);
    };

    requestAnimationFrame(step);
  };

  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (prefersReducedMotion) {
    counters.forEach((el) => {
      const numEl = el.querySelector<HTMLElement>(".counter-num");
      if (!numEl) return;
      const to = parseFloat(el.dataset.countTo ?? "0");
      const decimals = parseInt(el.dataset.countDecimals ?? "0", 10);
      numEl.textContent = format(to, decimals);
    });
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target as HTMLElement);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 }
    );
    counters.forEach((el) => io.observe(el));
  }

  // Reveal the 3 word badges above the laptop when they enter the viewport.
  const badgesGroups = document.querySelectorAll<HTMLElement>(".stats-badges");
  if (prefersReducedMotion) {
    badgesGroups.forEach((g) => g.classList.add("in-view"));
  } else {
    const badgeIO = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("in-view");
            badgeIO.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    badgesGroups.forEach((g) => badgeIO.observe(g));
  }
</script>
