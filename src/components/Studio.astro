---
// Fansportu sygnet is dark-stroked on white — invert filter turns it white,
// then the `studio-watermark` class drops opacity so it becomes a near-ink
// watermark sitting next to the headline.
const left = [
  "150 000+ subskrypcji YouTube",
  "Topowe postacie sportu",
  "KSW · GROMDA · eventy",
  "Studio + produkcja + dystrybucja",
];
const right = [
  "Lokowanie produktów w programach",
  "Wywiady sponsorowane",
  "Branded content",
  "Dystrybucja w milionowych zasięgach",
];
---

<section id="studio" class="py-28 lg:py-40 border-t border-white/10 bg-smoke">
  <style is:global>
    /* Sygnet is filled with the section bg colour and fully opaque,
       sitting ON TOP of an orbiting acid "kulka". The ball glows from
       below and is occluded wherever the sygnet's paths draw the
       F-shape, so only the negative space + outer orbit is visible. */
    .studio-watermark {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 2;
    }
    .studio-orbit {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
    }
    .studio-orbit::before {
      content: "";
      position: absolute;
      /* Ball locked slightly above centre (60% × 60%, top: 5%, left: 20%). */
      width: 60%;
      height: 60%;
      top: 5%;
      left: 20%;
      border-radius: 9999px;
      background:
        radial-gradient(
          circle,
          rgba(230, 255, 0, 0.55) 0%,
          rgba(230, 255, 0, 0.22) 40%,
          rgba(230, 255, 0, 0.08) 65%,
          transparent 78%
        );
      filter: blur(55px);
      will-change: transform, opacity;
      animation: studio-orbit-pulse 6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    }
    @keyframes studio-orbit-pulse {
      0%,
      100% {
        transform: scale(0.9);
        opacity: 0.55;
      }
      50% {
        transform: scale(1.15);
        opacity: 1;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .studio-orbit::before {
        animation: none;
      }
    }
  </style>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 relative">
    <div
      class="studio-logo-orbit hidden lg:block absolute top-0 right-[-3rem] xl:right-[-6rem] z-0 h-[clamp(20rem,38vw,40rem)] w-[clamp(20rem,38vw,40rem)] pointer-events-none"
      aria-hidden="true"
    >
      <div class="studio-orbit"></div>
      <svg
        class="studio-watermark select-none overflow-visible"
        viewBox="0 0 117.8 117.8"
        overflow="visible"
        xmlns="http://www.w3.org/2000/svg"
      >
      <defs>
        <!-- Inverted sygnet: a bg-smoke rectangle with the F-shape
             punched out, so the orbit ball behind is visible *inside*
             the F silhouette and blocked everywhere else. -->
        <mask id="studio-sygnet-cutout" maskUnits="userSpaceOnUse" x="0" y="0" width="117.8" height="117.8">
          <rect width="117.8" height="117.8" fill="white" />
          <path d="M39.8,17.8l-30.6,30.7h17.5v61.5L0,83.3v-48.8L34.5,0h48.8l17.8,17.8h-61.3Z" fill="black" />
          <path d="M117.8,34.5v48.8l-34.5,34.5h-48.8l-6.8-6.8,31.2-32.8h-20l9.7-9.6h20l20.1-20.1h-45.6l9.6-9.6h45.6l12-12,7.6,7.7h0Z" fill="black" />
        </mask>
      </defs>
      <rect
        width="117.8"
        height="117.8"
        fill="#15151a"
        mask="url(#studio-sygnet-cutout)"
      />
    </svg>
    </div>

    <div class="relative z-10 mb-16">
      <div class="text-xs uppercase tracking-[0.32em] text-acid">05 — Studio</div>
      <h2 class="mt-6 font-display font-semibold text-bone text-5xl lg:text-7xl">
        Fansportu&nbsp;TV<br />
        <span class="text-acid">własne</span> studio<br />
        produkcyjne
      </h2>
      <p class="mt-10 lg:mt-12 max-w-3xl text-lg text-bone/70 leading-relaxed">
        Profesjonalne studio, w którym powstają wywiady, programy sportowe i viralowe formaty. Łączymy jakość telewizyjną z dynamiką social mediów, tworząc treści, które realnie generują zasięgi.
      </p>
    </div>

    <div class="relative z-10 grid lg:grid-cols-12 gap-10">
      <figure class="lg:col-span-5 relative group overflow-hidden border border-white/10 bg-ink">
        <img
          src="/images/studio.jpg"
          alt="Wnętrze studia produkcyjnego Fansportu TV — ceglane ściany, oświetlenie sceniczne, stanowiska montażowe"
          width="932"
          height="1024"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover aspect-[932/1024] grayscale-[0.15] group-hover:grayscale-0 transition-all duration-700"
        />
        <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-ink/80 via-ink/0 to-ink/0"></div>
        <figcaption class="absolute bottom-0 inset-x-0 p-6 lg:p-8 flex items-end justify-between text-bone">
          <div>
            <div class="text-[10px] uppercase tracking-[0.32em] text-acid">Live · 24/7</div>
            <div class="font-display font-semibold text-2xl lg:text-3xl mt-2">Fansportu&nbsp;TV Studio</div>
          </div>
          <div class="text-right text-[10px] uppercase tracking-[0.18em] text-bone/60">
            Warszawa<br />Polska
          </div>
        </figcaption>
        <div class="absolute top-4 left-4 w-2 h-2 rounded-full bg-acid animate-pulse"></div>
      </figure>

      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
        <div class="border border-white/10 p-8 bg-ink flex flex-col">
          <div class="text-xs uppercase tracking-[0.32em] text-acid mb-6">Co tu się dzieje</div>
          <ul class="space-y-4 flex-1">
            {left.map((item) => (
              <li class="flex items-start gap-4 text-bone/85 text-base lg:text-lg">
                <span class="mt-3 w-3 h-px bg-acid inline-block shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="mailto:biuro@chaosmedia.pl?subject=Wynajem%20studia%20Fansportu%20TV"
            data-cursor="invert"
            class="group mt-8 inline-flex items-center justify-between gap-4 bg-acid text-ink px-6 py-4 font-display font-semibold text-sm lg:text-base uppercase tracking-[0.08em] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_18px_50px_-12px_rgba(230,255,0,0.55)] hover:bg-[#f0ff2e]"
          >
            Wynajmij studio
            <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="border border-white/10 p-8 bg-ink flex flex-col">
          <div class="text-xs uppercase tracking-[0.32em] text-acid mb-6">Twoja marka w naszym studio</div>
          <ul class="space-y-4 flex-1">
            {right.map((item) => (
              <li class="flex items-start gap-4 text-bone/85 text-base lg:text-lg">
                <span class="mt-3 w-3 h-px bg-acid inline-block shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-8 pt-6 border-t border-white/10 text-sm text-bone/50">
            Przykład: <span class="text-bone">format + dystrybucja</span> = milionowe wyświetlenia w 24h.
          </div>
          <a
            href="mailto:biuro@chaosmedia.pl?subject=Zlecenie%20kampanii%20w%20studiu%20Chaos%20Media"
            data-cursor="invert"
            class="group mt-6 inline-flex items-center justify-between gap-4 bg-acid text-ink px-6 py-4 font-display font-semibold text-sm lg:text-base uppercase tracking-[0.08em] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_18px_50px_-12px_rgba(230,255,0,0.55)] hover:bg-[#f0ff2e]"
          >
            Zleć kampanię
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
