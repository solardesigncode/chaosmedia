---
type Media = {
  name: string;
  logo: string;
  href: string;
  /** one-line description shown below the logo */
  desc: string;
  /** true for raster (avif/png/jpg) — gets CSS invert treatment */
  raster?: boolean;
};

const media: Media[] = [
  {
    name: "fansportu.pl",
    logo: "/logos/portals/fansportu.svg",
    href: "https://fansportu.pl",
    desc: "Portal sportowy",
  },
  {
    name: "strefamma.pl",
    logo: "/logos/portals/strefamma.svg",
    href: "https://strefamma.pl",
    desc: "Serwis o sportach walki",
  },
  {
    name: "mymma.pl",
    logo: "/logos/portals/mymma.svg",
    href: "https://mymma.pl",
    desc: "Magazyn MMA",
  },
  {
    name: "pantofelek.pl",
    logo: "/logos/portals/pantofelek.avif",
    href: "https://pantofelek.pl",
    desc: "Lifestyle kobiecy",
    raster: true,
  },
  {
    name: "filmiki.tv",
    logo: "/logos/portals/filmikitv.svg",
    href: "https://filmiki.tv",
    desc: "Rozrywka i wideo",
  },
  {
    name: "typowykibic.pl",
    logo: "/logos/portals/typowykibic.svg",
    href: "https://typowykibic.pl",
    desc: "Społeczność kibiców",
  },
  {
    name: "niewiarygodnemiejsca.pl",
    logo: "/logos/portals/niewiarygodnemiejsca.avif",
    href: "https://niewiarygodnemiejsca.pl",
    desc: "Podróże i odkrycia",
    raster: true,
  },
  {
    name: "watchcode.net",
    logo: "/logos/portals/watchcode.svg",
    href: "https://watchcode.net",
    desc: "Afiliacja",
  },
];
---

<section id="media" class="py-28 lg:py-40">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 mb-16 lg:mb-24">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
      <div class="lg:col-span-5">
        <div class="text-xs uppercase tracking-[0.32em] text-acid">01 — O nas</div>
        <h2 class="mt-6 font-display font-semibold text-bone text-6xl lg:text-7xl">Kim jesteśmy</h2>
      </div>
      <div class="lg:col-span-6 lg:col-start-7">
        <p class="text-lg text-bone/70 leading-relaxed">
          Chaos Media to agencja, która specjalizuje się w tworzeniu viralowych treści w social mediach. Posiadamy własne media, studio nagrań oraz zespoły reporterskie działające w całej Polsce.
        </p>
        <p class="mt-4 text-sm text-bone/40 uppercase tracking-[0.18em]">
          Własna dystrybucja · Własny content · Własne marki
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="mb-6 lg:mb-8 flex items-baseline justify-between">
      <div class="text-xs uppercase tracking-[0.32em] text-acid">Nasze portale</div>
      <div class="text-xs tracking-[0.18em] text-bone/30 tabular-nums">{media.length} / media</div>
    </div>

    <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4">
      {media.map((m, i) => (
        <li>
          <a
            href={m.href}
            target="_blank"
            rel="noopener noreferrer"
            class="portal-card group relative block border border-white/10 bg-smoke hover:border-acid hover:bg-ink transition-all p-5 lg:p-8 h-[240px] md:h-auto md:aspect-[5/4] flex flex-col justify-between overflow-hidden"
          >
            <span class="absolute top-3 left-3 text-[10px] tabular-nums text-bone/30">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span
              class="absolute top-3 right-3 text-bone/40 text-xl leading-none transition-all group-hover:text-acid group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              aria-hidden="true"
            >↗</span>

            <div class="h-16 lg:h-auto lg:flex-1 flex items-center justify-center pt-6 pb-4">
              <img
                src={m.logo}
                alt={`Logo ${m.name}`}
                loading="lazy"
                decoding="async"
                class:list={[
                  "portal-logo max-h-8 lg:max-h-12 max-w-[75%] object-contain transition-all duration-500",
                  m.raster ? "portal-logo--raster" : "",
                ]}
              />
            </div>

            <div class="border-t border-white/10 pt-3 lg:pt-4 group-hover:border-acid/40 transition-colors">
              <div class="font-sans font-semibold text-bone text-[13px] lg:text-lg tracking-tight truncate">
                {m.name}
              </div>
              <div class="mt-1 text-[10px] lg:text-xs text-bone/50 uppercase tracking-[0.14em] truncate">
                {m.desc}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style is:global>
  /* Raster logos (avif/png) — force into white silhouettes so they match
     the edited-white SVG logos aesthetically. */
  .portal-logo--raster {
    filter: brightness(0) invert(1);
  }
  .portal-card .portal-logo {
    opacity: 0.7;
  }
  .portal-card:hover .portal-logo {
    opacity: 1;
    transform: scale(1.05);
  }
</style>
