---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 py-12 lg:py-16">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 grid md:grid-cols-3 gap-8 items-end">
    <div>
      <div class="font-display font-semibold text-bone text-2xl tracking-tight">
        CHAOS MEDIA<sup class="text-acid">®</sup>
      </div>
      <div class="mt-2 text-sm text-bone/50">Chaos Media Sp. z o.o.</div>
    </div>
    <div class="text-sm text-bone/60 md:text-center">
      <a href="mailto:biuro@chaosmedia.pl" class="hover:text-acid transition-colors">biuro@chaosmedia.pl</a>
    </div>
    <div class="text-xs uppercase tracking-[0.18em] text-bone/40 md:text-right">
      © {year} · Wszystkie prawa zastrzeżone
    </div>
  </div>
</footer>
