<section id="kontakt" class="py-32 lg:py-48 relative overflow-hidden border-t border-white/10">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[80vw] h-[80vw] rounded-full bg-acid/[0.04] blur-3xl"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 text-center relative">
    <div class="text-xs uppercase tracking-[0.32em] text-acid">Kontakt</div>
    <h2 class="mt-6 font-display font-semibold text-bone text-[clamp(3rem,12vw,12rem)] leading-[0.85] tracking-[-0.045em]">
      Chcesz<br />
      <span class="accent-italic text-bone/65">ogromne</span><br />
      <span class="text-acid">zasięgi?</span>
    </h2>
    <p class="mt-10 text-lg lg:text-xl text-bone/70 max-w-xl mx-auto">
      Skontaktuj się z nami i stwórzmy viral razem.
    </p>

    <a
      href="mailto:biuro@chaosmedia.pl"
      class="mt-12 group inline-flex items-center gap-4 bg-acid text-ink px-10 py-6 font-display font-semibold text-2xl lg:text-3xl uppercase tracking-tight hover:gap-8 transition-all"
    >
      biuro@chaosmedia.pl
      <span aria-hidden="true">→</span>
    </a>
